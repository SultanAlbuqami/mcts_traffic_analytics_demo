# Environment Variables Reference
# Copy this file to .env and fill in values as needed.
# NEVER commit .env with real secrets.
#
# All variables are OPTIONAL. The app runs fully offline with defaults.

# ── Data Paths ─────────────────────────────────────────────────────────────────
# Override where the pipeline reads/writes data. Defaults to ./data/* and ./out/
# TRAFFIC_ANALYTICS_DATA_DIR=./data
# TRAFFIC_ANALYTICS_RAW_DIR=./data/raw
# TRAFFIC_ANALYTICS_STAGED_DIR=./data/staged
# TRAFFIC_ANALYTICS_CURATED_DIR=./data/curated
# TRAFFIC_ANALYTICS_PROCESSED_DIR=./data/processed
# TRAFFIC_ANALYTICS_OUT_DIR=./out
# TRAFFIC_ANALYTICS_POWERBI_DIR=./out/powerbi

# ── Logging ────────────────────────────────────────────────────────────────────
# TRAFFIC_ANALYTICS_LOG_LEVEL=INFO

# ── Pipeline Defaults ──────────────────────────────────────────────────────────
# TRAFFIC_ANALYTICS_DEFAULT_DAYS=365
# TRAFFIC_ANALYTICS_DEFAULT_SEED=42

# ── Streamlit ──────────────────────────────────────────────────────────────────
# TRAFFIC_ANALYTICS_STREAMLIT_PORT=8501

# ── LLM Integration (OPTIONAL — disabled by default) ──────────────────────────
# Set TRAFFIC_ANALYTICS_LLM_PROVIDER=disabled to force offline mode (default).
# Set to 'mock' for deterministic unit test stubs.
# Set to 'local_gateway' for a local LiteLLM/Ollama proxy.
#
# TRAFFIC_ANALYTICS_LLM_PROVIDER=disabled
# TRAFFIC_ANALYTICS_LLM_MODEL=local-qwen
# TRAFFIC_ANALYTICS_LLM_GATEWAY_URL=http://127.0.0.1:4000
# TRAFFIC_ANALYTICS_LLM_TIMEOUT_SECONDS=30
